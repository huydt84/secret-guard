# SecretGuard configuration example
# Place this file as .secretguard.yml in your project root.

version: 1

scan:
  git:
    working_tree: true
    staged: false
    history: false

  agents:
    enabled: true
    codex:
      enabled: true
      paths: []
    opencode:
      enabled: true
      paths: []
    copilot:
      enabled: true
      paths: []

  docker:
    enabled: false
    containers: true
    images: false
    compose: true
    dockerfile: true

report:
  format: terminal
  fail_on: high
  show_fingerprints: true
  show_secret_preview: true

redaction:
  backup: true
  mode: fingerprint
  in_place: false

allowlist:
  paths:
    - "testdata/**"
    - "docs/examples/**"
  fingerprints: []
  regexes:
    - "dummy_[A-Za-z0-9]+"

rules:
  custom: []
